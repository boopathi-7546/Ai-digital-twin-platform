# =====================================================================
# Frontend environment variables (Vite)
# Copy to `.env` for local development. Vite only exposes variables
# prefixed with VITE_ to client-side code.
# =====================================================================

# Base URL the frontend uses for all API calls.
# In local dev (vite dev server + backend on :8080), a proxy in
# vite.config.js forwards /api to http://localhost:8080, so this can
# stay as /api. In Docker, Nginx does the same proxying (see
# docker/nginx.conf), so /api also works there.
VITE_API_BASE_URL=/api
