# =====================================================================
# Backend environment variables
# Copy to `.env` (or export directly) for local development.
# In Docker Compose these are already wired up in docker-compose.yml —
# create a `.env` file at the repo root and Compose will pick it up.
# =====================================================================

# ---- Spring profile ----
SPRING_PROFILES_ACTIVE=dev

# ---- Database ----
DB_NAME=digital_twin_platform
DB_URL=jdbc:mysql://localhost:3306/digital_twin_platform?useSSL=false&serverTimezone=UTC&allowPublicKeyRetrieval=true
DB_USERNAME=root
DB_PASSWORD=root
DB_ROOT_PASSWORD=root

# ---- Server ----
SERVER_PORT=8080

# ---- JWT ----
# Generate a strong random value for production, e.g.: openssl rand -base64 48
JWT_SECRET=change-this-super-secret-key-in-prod-min-256-bits-long-value
JWT_ACCESS_EXP=3600000
JWT_REFRESH_EXP=604800000

# ---- CORS ----
CORS_ALLOWED_ORIGINS=http://localhost:5173

# ---- File storage ----
UPLOAD_DIR=./uploads

# ---- Frontend base URL (used to build email links) ----
FRONTEND_BASE_URL=http://localhost:5173

# ---- Mail (SMTP) ----
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=

# ---- Gemini API ----
GEMINI_API_KEY=
GEMINI_API_URL=https://generativelanguage.googleapis.com/v1beta/models/gemini-2.0-flash:generateContent
