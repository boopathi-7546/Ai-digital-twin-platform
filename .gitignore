# =====================================================================
# Root .gitignore — AI-Powered Digital Twin & Interview Readiness Platform
# =====================================================================

# ---- Environment files (never commit real secrets) ----
.env
.env.local
*.env
!*.env.example

# ---- Backend (Maven / Java) ----
backend/target/
backend/.mvn/wrapper/maven-wrapper.jar
*.class
*.jar
!backend/pom.xml
HELP.md

# ---- Uploaded files (local dev storage) ----
backend/uploads/
uploads/

# ---- Frontend (Node / Vite) ----
frontend/node_modules/
frontend/dist/
frontend/.vite/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ---- IDE / editor ----
.idea/
.vscode/
*.iml
*.swp
.DS_Store

# ---- Logs ----
*.log
logs/

# ---- OS ----
Thumbs.db
